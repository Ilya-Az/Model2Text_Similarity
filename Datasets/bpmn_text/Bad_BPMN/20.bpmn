<?xml version="1.0" ?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="Definitions_2"
             targetNamespace="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="Process_2">
    <startEvent id="StartEvent_1" name="start">
      <outgoing>SequenceFlow_1</outgoing>
    </startEvent>
    <task id="Task_1" name="Accountant receives and scans the invoice">
      <incoming>SequenceFlow_1</incoming>
      <outgoing>SequenceFlow_2</outgoing>
    </task>
    <task id="Task_2" name="Accountant enters invoice details into the ERP system">
      <incoming>SequenceFlow_2</incoming>
      <outgoing>SequenceFlow_3</outgoing>
    </task>
    <task id="Task_3" name="Manager reviews invoice for approval">
      <incoming>SequenceFlow_3</incoming>
      <outgoing>SequenceFlow_4</outgoing>
    </task>
    <exclusiveGateway id="ExclusiveGateway_1">
      <incoming>SequenceFlow_4</incoming>
      <outgoing>SequenceFlow_5</outgoing>
      <outgoing>SequenceFlow_6</outgoing>
    </exclusiveGateway>
    <task id="Task_4" name="Finance schedules payment">
      <incoming>SequenceFlow_5</incoming>
      <outgoing>SequenceFlow_7</outgoing>
    </task>
    <task id="Task_5" name="System sends payment confirmation to vendor">
      <incoming>SequenceFlow_7</incoming>
      <outgoing>SequenceFlow_8</outgoing>
    </task>
    <task id="Task_6" name="Accountant notifies vendor of rejection">
      <incoming>SequenceFlow_6</incoming>
      <outgoing>SequenceFlow_9</outgoing>
    </task>
    <exclusiveGateway id="ExclusiveGateway_2">
      <incoming>SequenceFlow_8</incoming>
      <incoming>SequenceFlow_9</incoming>
      <outgoing>SequenceFlow_10</outgoing>
    </exclusiveGateway>
    <endEvent id="EndEvent_1" name="end">
      <incoming>SequenceFlow_10</incoming>
    </endEvent>
    <sequenceFlow id="SequenceFlow_1" sourceRef="StartEvent_1" targetRef="Task_1"/>
    <sequenceFlow id="SequenceFlow_2" sourceRef="Task_1" targetRef="Task_2"/>
    <sequenceFlow id="SequenceFlow_3" sourceRef="Task_2" targetRef="Task_3"/>
    <sequenceFlow id="SequenceFlow_4" sourceRef="Task_3" targetRef="ExclusiveGateway_1"/>
    <sequenceFlow id="SequenceFlow_5" sourceRef="ExclusiveGateway_1" targetRef="Task_4"/>
    <sequenceFlow id="SequenceFlow_6" sourceRef="ExclusiveGateway_1" targetRef="Task_6"/>
    <sequenceFlow id="SequenceFlow_7" sourceRef="Task_4" targetRef="Task_5"/>
    <sequenceFlow id="SequenceFlow_8" sourceRef="Task_5" targetRef="ExclusiveGateway_2"/>
    <sequenceFlow id="SequenceFlow_9" sourceRef="Task_6" targetRef="ExclusiveGateway_2"/>
    <sequenceFlow id="SequenceFlow_10" sourceRef="ExclusiveGateway_2" targetRef="EndEvent_1"/>
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_2">
    <bpmndi:BPMNPlane id="BPMNPlane_2" bpmnElement="Process_2">
      <bpmndi:BPMNShape bpmnElement="StartEvent_1" id="StartEvent_1_di">
        <omgdc:Bounds x="57" y="52" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_1" id="Task_1_di">
        <omgdc:Bounds x="150" y="30" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_2" id="Task_2_di">
        <omgdc:Bounds x="310" y="30" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_3" id="Task_3_di">
        <omgdc:Bounds x="470" y="30" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="ExclusiveGateway_1" id="ExclusiveGateway_1_di">
        <omgdc:Bounds x="635" y="45" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_4" id="Task_4_di">
        <omgdc:Bounds x="745" y="30" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_5" id="Task_5_di">
        <omgdc:Bounds x="905" y="30" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_6" id="Task_6_di">
        <omgdc:Bounds x="745" y="170" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="ExclusiveGateway_2" id="ExclusiveGateway_2_di">
        <omgdc:Bounds x="1060" y="45" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="EndEvent_1" id="EndEvent_1_di">
        <omgdc:Bounds x="1167" y="52" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_1" id="SequenceFlow_1_di">
        <omgdi:waypoint x="93" y="70"/>
        <omgdi:waypoint x="150" y="70"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_2" id="SequenceFlow_2_di">
        <omgdi:waypoint x="250" y="70"/>
        <omgdi:waypoint x="310" y="70"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_3" id="SequenceFlow_3_di">
        <omgdi:waypoint x="410" y="70"/>
        <omgdi:waypoint x="470" y="70"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_4" id="SequenceFlow_4_di">
        <omgdi:waypoint x="570" y="70"/>
        <omgdi:waypoint x="635" y="70"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_5" id="SequenceFlow_5_di">
        <omgdi:waypoint x="685" y="70"/>
        <omgdi:waypoint x="745" y="70"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_6" id="SequenceFlow_6_di">
        <omgdi:waypoint x="660" y="95"/>
        <omgdi:waypoint x="660" y="210"/>
        <omgdi:waypoint x="745" y="210"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_7" id="SequenceFlow_7_di">
        <omgdi:waypoint x="845" y="70"/>
        <omgdi:waypoint x="905" y="70"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_8" id="SequenceFlow_8_di">
        <omgdi:waypoint x="1005" y="70"/>
        <omgdi:waypoint x="1060" y="70"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_9" id="SequenceFlow_9_di">
        <omgdi:waypoint x="845" y="210"/>
        <omgdi:waypoint x="1085" y="210"/>
        <omgdi:waypoint x="1085" y="95"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_10" id="SequenceFlow_10_di">
        <omgdi:waypoint x="1110" y="70"/>
        <omgdi:waypoint x="1167" y="70"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>