<?xml version="1.0" ?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="Definitions_1"
             targetNamespace="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="Process_1">
    <startEvent id="StartEvent_1" name="start">
      <outgoing>SequenceFlow_1</outgoing>
    </startEvent>
    <task id="Task_1" name="HR sends welcome package to new employee">
      <incoming>SequenceFlow_1</incoming>
      <outgoing>SequenceFlow_2</outgoing>
    </task>
    <parallelGateway id="ParallelGateway_1">
      <incoming>SequenceFlow_2</incoming>
      <outgoing>SequenceFlow_3</outgoing>
      <outgoing>SequenceFlow_4</outgoing>
    </parallelGateway>
    <task id="Task_2" name="IT creates user account and configures workstation">
      <incoming>SequenceFlow_3</incoming>
      <outgoing>SequenceFlow_5</outgoing>
    </task>
    <task id="Task_3" name="Manager introduces employee to the team">
      <incoming>SequenceFlow_4</incoming>
      <outgoing>SequenceFlow_6</outgoing>
    </task>
    <parallelGateway id="ParallelGateway_2">
      <incoming>SequenceFlow_5</incoming>
      <incoming>SequenceFlow_6</incoming>
      <outgoing>SequenceFlow_7</outgoing>
    </parallelGateway>
    <task id="Task_4" name="Employee completes compliance training">
      <incoming>SequenceFlow_7</incoming>
      <outgoing>SequenceFlow_8</outgoing>
    </task>
    <task id="Task_5" name="HR registers employee in payroll system">
      <incoming>SequenceFlow_8</incoming>
      <outgoing>SequenceFlow_9</outgoing>
    </task>
    <endEvent id="EndEvent_1" name="end">
      <incoming>SequenceFlow_9</incoming>
    </endEvent>
    <sequenceFlow id="SequenceFlow_1" sourceRef="StartEvent_1" targetRef="Task_1"/>
    <sequenceFlow id="SequenceFlow_2" sourceRef="Task_1" targetRef="ParallelGateway_1"/>
    <sequenceFlow id="SequenceFlow_3" sourceRef="ParallelGateway_1" targetRef="Task_2"/>
    <sequenceFlow id="SequenceFlow_4" sourceRef="ParallelGateway_1" targetRef="Task_3"/>
    <sequenceFlow id="SequenceFlow_5" sourceRef="Task_2" targetRef="ParallelGateway_2"/>
    <sequenceFlow id="SequenceFlow_6" sourceRef="Task_3" targetRef="ParallelGateway_2"/>
    <sequenceFlow id="SequenceFlow_7" sourceRef="ParallelGateway_2" targetRef="Task_4"/>
    <sequenceFlow id="SequenceFlow_8" sourceRef="Task_4" targetRef="Task_5"/>
    <sequenceFlow id="SequenceFlow_9" sourceRef="Task_5" targetRef="EndEvent_1"/>
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1">
      <bpmndi:BPMNShape bpmnElement="StartEvent_1" id="StartEvent_1_di">
        <omgdc:Bounds x="57" y="52" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_1" id="Task_1_di">
        <omgdc:Bounds x="150" y="30" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="ParallelGateway_1" id="ParallelGateway_1_di">
        <omgdc:Bounds x="310" y="45" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_2" id="Task_2_di">
        <omgdc:Bounds x="420" y="30" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_3" id="Task_3_di">
        <omgdc:Bounds x="420" y="170" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="ParallelGateway_2" id="ParallelGateway_2_di">
        <omgdc:Bounds x="585" y="45" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_4" id="Task_4_di">
        <omgdc:Bounds x="695" y="30" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Task_5" id="Task_5_di">
        <omgdc:Bounds x="855" y="30" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="EndEvent_1" id="EndEvent_1_di">
        <omgdc:Bounds x="1017" y="52" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_1" id="SequenceFlow_1_di">
        <omgdi:waypoint x="93" y="70"/>
        <omgdi:waypoint x="150" y="70"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_2" id="SequenceFlow_2_di">
        <omgdi:waypoint x="250" y="70"/>
        <omgdi:waypoint x="310" y="70"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_3" id="SequenceFlow_3_di">
        <omgdi:waypoint x="360" y="70"/>
        <omgdi:waypoint x="420" y="70"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_4" id="SequenceFlow_4_di">
        <omgdi:waypoint x="335" y="95"/>
        <omgdi:waypoint x="335" y="210"/>
        <omgdi:waypoint x="420" y="210"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_5" id="SequenceFlow_5_di">
        <omgdi:waypoint x="520" y="70"/>
        <omgdi:waypoint x="585" y="70"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_6" id="SequenceFlow_6_di">
        <omgdi:waypoint x="520" y="210"/>
        <omgdi:waypoint x="610" y="210"/>
        <omgdi:waypoint x="610" y="95"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_7" id="SequenceFlow_7_di">
        <omgdi:waypoint x="635" y="70"/>
        <omgdi:waypoint x="695" y="70"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_8" id="SequenceFlow_8_di">
        <omgdi:waypoint x="795" y="70"/>
        <omgdi:waypoint x="855" y="70"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_9" id="SequenceFlow_9_di">
        <omgdi:waypoint x="955" y="70"/>
        <omgdi:waypoint x="1017" y="70"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>