<process>
    <loopGateway id="loopgateway1">
        <branch condition="No" id="branch1">
            <activity role="" action="Develop basic design" objects="" id="activity1"/>
            <exclusiveGateway id="exclusivegateway1" decision="Brick sets already ordered?">
                <branch condition="No" id="branch2">
                    <activity role="" action="Order Lego brick sets" objects="" id="activity2"/>
                    <activity role="" action="Give the lego sets to the children" objects="" id="activity3"/>
                    <activity role="" action="Sort the parts into containers" objects="" id="activity4"/>
                </branch>
                <branch condition="Yes" id="branch3"/>
            </exclusiveGateway>
            <loopGateway id="loopgateway2">
                <branch condition="Yes" id="branch4">
                    <exclusiveGateway id="exclusivegateway2" decision="Container empty?">
                        <branch condition="Yes" id="branch5">
                            <activity role="" action="Reorder parts" objects="" id="activity5"/>
                        </branch>
                        <branch condition="No" id="branch6"/>
                    </exclusiveGateway>
                    <activity role="" action="Build the next subcomponent" objects="" id="activity6"/>
                </branch>
            </loopGateway>
            <parallelGateway id="parallelgateway1">
                <branch condition="" id="branch7">
                    <activity role="" action="Test subcomponent 1" objects="" id="activity7"/>
                </branch>
                <branch condition="" id="branch8">
                    <activity role="" action="Test subcomponent 4" objects="" id="activity8"/>
                </branch>
                <branch condition="" id="branch9">
                    <activity role="" action="Test subcomponent 2" objects="" id="activity9"/>
                </branch>
                <branch condition="" id="branch10">
                    <activity role="" action="Test subcomponent 3" objects="" id="activity10"/>
                </branch>
            </parallelGateway>
        </branch>
    </loopGateway>
    <activity role="" action="Assemble subcomponents" objects="" id="activity11"/>
</process>