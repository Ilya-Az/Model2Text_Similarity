<process>
    <exclusiveGateway id="exclusivegateway1" decision="Have an account?">
        <branch condition="No" id="branch1">
            <activity role="" action="Create account" objects="" id="activity1"/>
        </branch>
        <branch condition="Yes" id="branch2"/>
    </exclusiveGateway>
    <loopGateway id="loopgateway1">
        <branch condition="No" id="branch3">
            <activity role="" action="Log into account" objects="" id="activity2"/>
        </branch>
    </loopGateway>
    <activity role="" action="Select device model" objects="" id="activity3"/>
    <activity role="" action="Select type of hardware Issue" objects="" id="activity4"/>
    <parallelGateway id="parallelgateway1">
        <branch condition="" id="branch4">
            <activity role="" action="List required materials" objects="" id="activity5"/>
        </branch>
        <branch condition="" id="branch5">
            <activity role="" action="List required tools" objects="" id="activity6"/>
        </branch>
        <branch condition="" id="branch6">
            <activity role="" action="Offer ordering choices" objects="" id="activity7"/>
        </branch>
    </parallelGateway>
    <exclusiveGateway id="exclusivegateway2" decision="Have all required items?">
        <branch condition="No" id="branch7">
            <exclusiveGateway id="exclusivegateway3" decision="Have intention to get second-hand items?">
                <branch condition="No" id="branch8"/>
                <branch condition="Yes" id="branch9">
                    <activity role="" action="Contact friends" objects="" id="activity8"/>
                    <activity role="" action="Get second-hand tools and materials from friends" objects="" id="activity9"/>
                </branch>
            </exclusiveGateway>
            <exclusiveGateway id="exclusivegateway4" decision="Have intention to purchase new items?">
                <branch condition="Yes" id="branch10">
                    <activity role="" action="purchase online" objects="" id="activity10"/>
                </branch>
                <branch condition="No" id="branch11"/>
            </exclusiveGateway>
        </branch>
        <branch condition="Yes" id="branch12"/>
    </exclusiveGateway>
    <activity role="" action="Display repair instructions" objects="" id="activity11"/>
    <activity role="" action="Repair device" objects="" id="activity12"/>
    <exclusiveGateway id="exclusivegateway5" decision="Is issue fixed?">
        <branch condition="No" id="branch13">
            <activity role="" action="Send device to an expert" objects="" id="activity13"/>
        </branch>
        <branch condition="Yes" id="branch14">
            <exclusiveGateway id="exclusivegateway6" decision="Have intention to write a review?">
                <branch condition="Yes" id="branch15">
                    <activity role="" action="Write review" objects="" id="activity14"/>
                </branch>
                <branch condition="No" id="branch16"/>
            </exclusiveGateway>
            <exclusiveGateway id="exclusivegateway7" decision="Have intention to upload a video of repair steps?">
                <branch condition="No" id="branch17"/>
                <branch condition="Yes" id="branch18">
                    <activity role="" action="Upload video of reparation steps" objects="" id="activity15"/>
                </branch>
            </exclusiveGateway>
        </branch>
    </exclusiveGateway>
</process>