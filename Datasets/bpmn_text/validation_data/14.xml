<process>
    <activity role="" action="Select type of order" objects="" id="activity1"/>
    <exclusiveGateway id="exclusivegateway1" decision="Menu or just the burger ?">
        <branch condition="With menu" id="branch1">
            <activity role="" action="Select menu" objects="" id="activity2"/>
            <activity role="" action="Select type of beverage" objects="" id="activity3"/>
            <parallelGateway id="parallelgateway1">
                <branch condition="" id="branch2">
                    <activity role="" action="Prepare beverage" objects="" id="activity4"/>
                </branch>
                <branch condition="" id="branch3">
                    <activity role="" action="Select side" objects="" id="activity5"/>
                </branch>
            </parallelGateway>
            <exclusiveGateway id="exclusivegateway2" decision="Fries or wedges ?">
                <branch condition="Potato wedges" id="branch4">
                    <activity role="" action="Prepare potato wedges" objects="" id="activity6"/>
                </branch>
                <branch condition="French fries" id="branch5">
                    <activity role="" action="Prepare French fries" objects="" id="activity7"/>
                </branch>
            </exclusiveGateway>
        </branch>
        <branch condition="Burger only" id="branch6">
            <activity role="" action="Select burger" objects="" id="activity8"/>
        </branch>
    </exclusiveGateway>
    <activity role="" action="Make payment" objects="" id="activity9"/>
    <activity role="" action="Enter customer's name" objects="" id="activity10"/>
    <parallelGateway id="parallelgateway2">
        <branch condition="" id="branch7">
            <loopGateway id="loopgateway1">
                <branch condition="No" id="branch8">
                    <activity role="" action="Update status" objects="" id="activity11"/>
                    <event description="30 seconds" id="event1"/>
                    <activity role="" action="Check status" objects="" id="activity12"/>
                </branch>
            </loopGateway>
        </branch>
        <branch condition="" id="branch9">
            <activity role="" action="Prepare burger" objects="" id="activity13"/>
        </branch>
    </parallelGateway>
    <activity role="" action="Notify customer" objects="" id="activity14"/>
    <activity role="" action="Deliver via conveyor belt" objects="" id="activity15"/>
</process>